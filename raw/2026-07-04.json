[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11172, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2379, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 545059, "username": "rxswift", "url": "https://www.v2ex.com/u/rxswift", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_mini.png?m=1750306012", "avatar_normal": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_normal.png?m=1750306012", "avatar_large": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_large.png?m=1750306012", "avatar_xlarge": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_xlarge.png?m=1750306012", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_xxlarge.png?m=1750306012", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_xxxlarge.png?m=1750306012", "created": 1620724109, "last_modified": 1750306012, "pro": 0}, "last_reply_by": "unused", "last_touched": 1783125363, "title": "看《感觉女友很爱去看演唱会，不想让她去怎么办》有感，人生真正的享受是什么", "url": "https://www.v2ex.com/t/1224760", "created": 1783061557, "deleted": 0, "content": "贴一下原文：[感觉女友很爱去看演唱会，不想让她去怎么办]( https://www.v2ex.com/t/1224428#reply273)  \r\n作为我个人肯定觉得去看演唱会，费钱又费精力。不如自己呆在空调房里，打打游戏、睡睡觉、vibecoding 一下、看看电影。    \r\n但从他女朋友的角度，可能人家就是喜欢追星呢，就喜欢花大几千去看演唱会呢  \r\n各位觉得人生真正的享受是什么样的", "content_rendered": "<p>贴一下原文：<a href=\"https://www.v2ex.com/t/1224428#reply273\" rel=\"nofollow\">感觉女友很爱去看演唱会，不想让她去怎么办</a><br/>\n作为我个人肯定觉得去看演唱会，费钱又费精力。不如自己呆在空调房里，打打游戏、睡睡觉、vibecoding 一下、看看电影。<br/>\n但从他女朋友的角度，可能人家就是喜欢追星呢，就喜欢花大几千去看演唱会呢<br/>\n各位觉得人生真正的享受是什么样的</p>\n", "last_modified": 1783082198, "replies": 89, "id": 1224760}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71871, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9720, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 571634, "username": "123128xyz", "url": "https://www.v2ex.com/u/123128xyz", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=73&d=retro", "created": 1643703509, "last_modified": 1782739315, "pro": 0}, "last_reply_by": "ouqihang", "last_touched": 1783124408, "title": "我预判，第一波 AI 洪峰已过！", "url": "https://www.v2ex.com/t/1224778", "created": 1783065265, "deleted": 0, "content": "AI coding 趋势终于拐点了！\r\n\r\n**我预判，第一波 AI 洪峰已过。**\r\n\r\n\r\n据我观察**4 个方面**:\r\n\r\n1 、第三方价格数据(暴跌，需求减少)：\r\n\r\nGeminiPro 一年会员自动开通 CDK 包绑卡订阅 **¥12**\r\n\r\nChatGPT  [带 RT ]  [ Plus 成品号]  **¥15**\r\n\r\n2 、v 站数据（话题占比下降）：\r\n\r\n据观察 V 站上月 AI 话题占比趋近 100%，当前占比也有下降趋势\r\n\r\n3 、个人数据：\r\n\r\n短期使用量，也明显下跌。不可能永远有新项目，只有初版稳定之后就不会再有暴力 token 需求。\r\n\r\n4 、小红书数据：\r\n\r\n前段时间->vibe coding 帖子热度极高。\r\n\r\n很多**不懂代码的人**。\r\n\r\n偶然有一个/多个想法->开通 ai 会员(短期)->生成 app （养猫\\遛狗\\逗娃..）\r\n\r\n后面在于推广维护，短期很难再有一个新想法。\r\n\r\n**看懂趋势比埋头苦干更有价值！**\r\n\r\n真的需要，**说说大家的感觉**，比如公司使用，个人观察，中转站数据？", "content_rendered": "<p>AI coding 趋势终于拐点了！</p>\n<p><strong>我预判，第一波 AI 洪峰已过。</strong></p>\n<p>据我观察<strong>4 个方面</strong>:</p>\n<p>1 、第三方价格数据(暴跌，需求减少)：</p>\n<p>GeminiPro 一年会员自动开通 CDK 包绑卡订阅 <strong>¥12</strong></p>\n<p>ChatGPT  [带 RT ]  [ Plus 成品号]  <strong>¥15</strong></p>\n<p>2 、v 站数据（话题占比下降）：</p>\n<p>据观察 V 站上月 AI 话题占比趋近 100%，当前占比也有下降趋势</p>\n<p>3 、个人数据：</p>\n<p>短期使用量，也明显下跌。不可能永远有新项目，只有初版稳定之后就不会再有暴力 token 需求。</p>\n<p>4 、小红书数据：</p>\n<p>前段时间-&gt;vibe coding 帖子热度极高。</p>\n<p>很多<strong>不懂代码的人</strong>。</p>\n<p>偶然有一个/多个想法-&gt;开通 ai 会员(短期)-&gt;生成 app （养猫\\遛狗\\逗娃..）</p>\n<p>后面在于推广维护，短期很难再有一个新想法。</p>\n<p><strong>看懂趋势比埋头苦干更有价值！</strong></p>\n<p>真的需要，<strong>说说大家的感觉</strong>，比如公司使用，个人观察，中转站数据？</p>\n", "last_modified": 1783065487, "replies": 73, "id": 1224778}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239658, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4497, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 604449, "username": "gotOwt", "url": "https://www.v2ex.com/u/gotOwt", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_mini.png?m=1781573104", "avatar_normal": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_normal.png?m=1781573104", "avatar_large": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_large.png?m=1781573104", "avatar_xlarge": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_xlarge.png?m=1781573104", "created": 1669943889, "last_modified": 1781573104, "pro": 0}, "last_reply_by": "unused", "last_touched": 1783091945, "title": "家里孩子生了，请帮忙取个名字", "url": "https://www.v2ex.com/t/1224777", "creat