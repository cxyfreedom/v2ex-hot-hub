[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71872, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9720, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 571634, "username": "123128xyz", "url": "https://www.v2ex.com/u/123128xyz", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=73&d=retro", "created": 1643703509, "last_modified": 1782739315, "pro": 0}, "last_reply_by": "aaa0009", "last_touched": 1783128008, "title": "我预判，第一波 AI 洪峰已过！", "url": "https://www.v2ex.com/t/1224778", "created": 1783065265, "deleted": 0, "content": "AI coding 趋势终于拐点了！\r\n\r\n**我预判，第一波 AI 洪峰已过。**\r\n\r\n\r\n据我观察**4 个方面**:\r\n\r\n1 、第三方价格数据(暴跌，需求减少)：\r\n\r\nGeminiPro 一年会员自动开通 CDK 包绑卡订阅 **¥12**\r\n\r\nChatGPT  [带 RT ]  [ Plus 成品号]  **¥15**\r\n\r\n2 、v 站数据（话题占比下降）：\r\n\r\n据观察 V 站上月 AI 话题占比趋近 100%，当前占比也有下降趋势\r\n\r\n3 、个人数据：\r\n\r\n短期使用量，也明显下跌。不可能永远有新项目，只有初版稳定之后就不会再有暴力 token 需求。\r\n\r\n4 、小红书数据：\r\n\r\n前段时间->vibe coding 帖子热度极高。\r\n\r\n很多**不懂代码的人**。\r\n\r\n偶然有一个/多个想法->开通 ai 会员(短期)->生成 app （养猫\\遛狗\\逗娃..）\r\n\r\n后面在于推广维护，短期很难再有一个新想法。\r\n\r\n**看懂趋势比埋头苦干更有价值！**\r\n\r\n真的需要，**说说大家的感觉**，比如公司使用，个人观察，中转站数据？", "content_rendered": "<p>AI coding 趋势终于拐点了！</p>\n<p><strong>我预判，第一波 AI 洪峰已过。</strong></p>\n<p>据我观察<strong>4 个方面</strong>:</p>\n<p>1 、第三方价格数据(暴跌，需求减少)：</p>\n<p>GeminiPro 一年会员自动开通 CDK 包绑卡订阅 <strong>¥12</strong></p>\n<p>ChatGPT  [带 RT ]  [ Plus 成品号]  <strong>¥15</strong></p>\n<p>2 、v 站数据（话题占比下降）：</p>\n<p>据观察 V 站上月 AI 话题占比趋近 100%，当前占比也有下降趋势</p>\n<p>3 、个人数据：</p>\n<p>短期使用量，也明显下跌。不可能永远有新项目，只有初版稳定之后就不会再有暴力 token 需求。</p>\n<p>4 、小红书数据：</p>\n<p>前段时间-&gt;vibe coding 帖子热度极高。</p>\n<p>很多<strong>不懂代码的人</strong>。</p>\n<p>偶然有一个/多个想法-&gt;开通 ai 会员(短期)-&gt;生成 app （养猫\\遛狗\\逗娃..）</p>\n<p>后面在于推广维护，短期很难再有一个新想法。</p>\n<p><strong>看懂趋势比埋头苦干更有价值！</strong></p>\n<p>真的需要，<strong>说说大家的感觉</strong>，比如公司使用，个人观察，中转站数据？</p>\n", "last_modified": 1783065487, "replies": 74, "id": 1224778}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239654, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4497, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 623288, "username": "Y25tIGxpdmlk", "url": "https://www.v2ex.com/u/Y25tIGxpdmlk", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=73&d=retro", "created": 1681019214, "last_modified": 1716984949, "pro": 0}, "last_reply_by": "MaGa0221", "last_touched": 1783150073, "title": "暗色模式到底是怎么流行起来的？？", "url": "https://www.v2ex.com/t/1224886", "created": 1783131113, "deleted": 0, "content": "RT ，现在基本上但凡 IT 数码沾点边的站点或者软件，进去默认都是夜间模式、暗色模式。\r\n作为一个讨厌暗色模式的人，每次进去都要找半天日渐模式按钮在哪里，有些在右上角或者左下角直接可以切换的还好。\r\n有些 TM 的直接没有切换按钮或者藏在设置页深处的，简直想打人。\r\n\r\n夜间模式到底好在哪里啊？护眼吗？好像没有科学依据证明啊。\r\n日间模式看着多舒服啊，各种设计颜色都是原始的，夜间模式好多界面颜色啥的设计都变乱了，很丑啊。", "content_rendered": "RT ，现在基本上但凡 IT 数码沾点边的站点或者软件，进去默认都是夜间模式、暗色模式。<br />作为一个讨厌暗色模式的人，每次进去都要找半天日渐模式按钮在哪里，有些在右上角或者左下角直接可以切换的还好。<br />有些 TM 的直接没有切换按钮或者藏在设置页深处的，简直想打人。<br /><br />夜间模式到底好在哪里啊？护眼吗？好像没有科学依据证明啊。<br />日间模式看着多舒服啊，各种设计颜色都是原始的，夜间模式好多界面颜色啥的设计都变乱了，很丑啊。", "last_modified": 1783131113, "replies": 67, "id": 1224886}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239654, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4497, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 604449, "username": "gotOwt", "url": "https://www.v2ex.com/u/gotOwt", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_mini.png?m=1781573104", "avatar_normal": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_normal.png?m=1781573104", "avatar_large": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_large.png?m=1781573104", "avatar_xlarge": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_xlarge.png?m=1781573104", "created": 1669943889, "last_modified": 1781573104, "pro": 0}, "last_reply_by": "oLUCKo", "last_touched": 1783095545, "title": "家里孩子生了，请帮忙取个名字", "url": "https://www.v2ex.com/t/1224777", "created": 1783065171, "deleted": 0, "content": "姓先不跟你们说了。\r\n麻烦帮忙取下吧。", "content_rendered": "<p>姓先不跟你们说了。\n麻烦帮忙取下吧。</p>\n", "last_modified": 1783065191, "replies": 51, "id": 1224777}, {"node": {"avatar_large": "http