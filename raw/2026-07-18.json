[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11260, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2399, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 225840, "username": "zsxzy", "url": "https://www.v2ex.com/u/zsxzy", "website": "iosair.cn", "twitter": "", "psn": "", "github": "xfirefly", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/6ced/5cd3/225840_mini.png?m=1750605867", "avatar_normal": "https://cdn.v2ex.com/avatar/6ced/5cd3/225840_normal.png?m=1750605867", "avatar_large": "https://cdn.v2ex.com/avatar/6ced/5cd3/225840_large.png?m=1750605867", "created": 1492064566, "last_modified": 1750605867, "pro": 0}, "last_reply_by": "Hapon", "last_touched": 1784363172, "title": "纯功利的角度, 如何为孩子选兴趣班？", "url": "https://www.v2ex.com/t/1228170", "created": 1784342900, "deleted": 0, "content": "孩子才 8 岁，报了好几个兴趣班：羽毛球、舞蹈、武术、钢琴、绘画。\r\n\r\n如果站在纯功利角度，以普通家庭、普通孩子的条件来考虑，优先选**低投入、高确定性、长期有用**的项目，\r\n\r\n应该重点深耕哪一个？有更好的项目吗", "content_rendered": "<p>孩子才 8 岁，报了好几个兴趣班：羽毛球、舞蹈、武术、钢琴、绘画。</p>\n<p>如果站在纯功利角度，以普通家庭、普通孩子的条件来考虑，优先选<strong>低投入、高确定性、长期有用</strong>的项目，</p>\n<p>应该重点深耕哪一个？有更好的项目吗</p>\n", "last_modified": 1784342900, "replies": 66, "id": 1228170}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/3c59/dc04/21_large.png?m=1650127623", "name": "shenzhen", "avatar_normal": "https://cdn.v2ex.com/navatar/3c59/dc04/21_normal.png?m=1650127623", "title": "深圳", "url": "https://www.v2ex.com/go/shenzhen", "topics": 3573, "footer": "", "header": "", "title_alternative": "Shenzhen", "avatar_mini": "https://cdn.v2ex.com/navatar/3c59/dc04/21_mini.png?m=1650127623", "stars": 2136, "founder_id": 0, "aliases": [], "root": false, "id": 21, "parent_node_name": "cn"}, "member": {"id": 588794, "username": "davinci21s", "url": "https://www.v2ex.com/u/davinci21s", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/7a4c4bbb84322b069036d29ad8e1658e?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/7a4c4bbb84322b069036d29ad8e1658e?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/7a4c4bbb84322b069036d29ad8e1658e?s=73&d=retro", "created": 1658391108, "last_modified": 1695025708, "pro": 0}, "last_reply_by": "yiranw09", "last_touched": 1784362617, "title": "深圳的西瓜是镶了金边吗，这么贵", "url": "https://www.v2ex.com/t/1228103", "created": 1784289900, "deleted": 0, "content": "实体店普遍最便宜的麒麟瓜都要 5 元/斤\r\n\r\n外卖最便宜的叮咚买菜都接近 3.5/斤，但是运费要 7 元！！！\r\n\r\n无力吐槽！！\r\n\r\n坐标，深圳南山。", "content_rendered": "<p>实体店普遍最便宜的麒麟瓜都要 5 元/斤</p>\n<p>外卖最便宜的叮咚买菜都接近 3.5/斤，但是运费要 7 元！！！</p>\n<p>无力吐槽！！</p>\n<p>坐标，深圳南山。</p>\n", "last_modified": 1784289938, "replies": 54, "id": 1228103}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 240036, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4499, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 276277, "username": "chniccs", "url": "https://www.v2ex.com/u/chniccs", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/62031a8745e8929e0be3dd99908a97cf?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/62031a8745e8929e0be3dd99908a97cf?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/62031a8745e8929e0be3dd99908a97cf?s=73&d=retro", "created": 1513927680, "last_modified": 1703469299, "pro": 0}, "last_reply_by": "oamu", "last_touched": 1784364038, "title": "假如没有厕纸了，你用什么？", "url": "https://www.v2ex.com/t/1228159", "created": 1784339422, "deleted": 0, "content": "坐标江西，小时候在乡下，那时候厕纸还是高级货，没多少人有，小伙伴出去玩，中途释放完之后，会使用竹片刮（不是擦，是刮）屁股，现在就好奇，江西竹子多所以用竹子，那其它地方的人在没厕纸的情况下都用什么？", "content_rendered": "坐标江西，小时候在乡下，那时候厕纸还是高级货，没多少人有，小伙伴出去玩，中途释放完之后，会使用竹片刮（不是擦，是刮）屁股，现在就好奇，江西竹子多所以用竹子，那其它地方的人在没厕纸的情况下都用什么？", "last_modified": 1784339422, "replies": 51, "id": 1228159}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 240036, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4499, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 111998, "username": "flyico", "url": "https://www.v2ex.com/u/flyico", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/3907/99d0/111998_mini.png?m=1735525820", "avatar_normal": "https://cdn.v2ex.com/avatar/3907/99d0/111998_normal.png?m=1735525820", "avatar_large": "https://cdn.v2ex.com/avatar/3907/99d0/111998_large.png?m=1735525820", "avatar_xlarge": "https://cdn.v2ex.com/avatar/3907/99d0/111998_xlarge.png?m=1735525820", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/3907/99d0/111998_xxlarge.png?m=1735525820", "created": 1429508703, "last_modified": 1735525820, "pro": 0}, "last_reply_by": "bugmakerxs", "last_touched": 1784360798, "title": "现在中国哪里还能看到肉眼看到银河？", "url": "https://www.v2ex.com/t/1228090", "created": 1784283671, "deleted": 0, "content": "孩子最近对星空很感兴趣，我告诉他，记得我小时候大概 90 年代初，我所在的城市夜晚还是能清晰的用肉眼看到银河的，那时候星光甚至都能照亮道路，可惜现在已经不行了，每次说到这里，他总是表现出无限的遗憾，所以，现在中国哪里还能看到银河呢？", "content_rendered": "孩子最近对星空很感兴趣，我告诉他，记得我小时候大概 90 年代初，我所在的城市夜晚还是能清晰的用肉眼看到银河的，那时候星光甚至都能照亮道路，可惜现在已经不行了，每次说到这里，他总是表现出无限的遗憾，所以，现在中国哪里还能看到银河呢？", "last_modified": 1784283671, "replies": 42, "id": 1228090}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_large.png?m=1751736785", "name": "openai", "avatar_normal": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_normal.png?m=1751736785", "title": "OpenAI", "url": "https://www.v2ex.com/go/openai", "topics": 4321, "footer": "", "header": "关于 OpenAI 旗下产品 GPT，DALL·E，和 ChatGPT 的讨论。请不要在 V2EX 的回复中粘贴复制来自 AI 生成的文本。", "title_alternative": "OpenAI", "avatar_mini": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_mini.png?m=1751736785", "stars": 3225, "founder_id": 0, "aliases": [], "root": false, "id": 1135, "parent_node_name": "geek"}, "member": {"id": 238062, "username": "johnsonhk", "url": "https://www.v2ex.com/u/johnsonhk", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/6e1df90fea4e7dfbc7e019cbb1b83356?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/6e1df90fea4e7dfbc7e019cbb1b83356?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/6e1df90fea4e7dfbc7e019cbb1b83356?s=73&d=retro", "created": 1498818608, "last_modified": 1498818608, "pro": 0}, "last_reply_by": "chrosing", "last_touched": 1784347698, "title": "18 号到期的重置，本来想着今天用的，结果。。。", "url": "https://www.v2ex.com/t/1228155", "created": 1784337150, "deleted": 0, "content": "今天 18 号一大早就发现重置已经没有了。。。。。。", "content_rendered": "<p>今天 18 号一大早就发现重置已经没有了。。。。。。</p>\n", "last_modified": 1784337150, "replies": 29, "id": 1228155}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 72133, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9729, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 510940, "username": "retaniko", "url": "https://www.v2ex.com/u/retaniko", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/c47b543e6245d83a2c58305aee5e17d2?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/c47b543e6245d83a2c58305aee5e17d2?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/c47b543e6245d83a2c58305aee5e17d2?s=73&d=retro", "created": 1601604027, "last_modified": 1784289465, "pro": 0}, "last_reply_by": "yazinnnn0", "last_touched": 1784342631, "title": "Kimi k3， gpt5.6， gemini3.1 生成的单页面哪个好看", "url": "https://www.v2ex.com/t/1228104", "created": 1784290461, "deleted": 0, "content": "一句话提示词：生成水墨风格的网站留言板页面\r\n\r\ngemini3.1 pro： https://preview.kaka770.cn/tools/html-share?share=h8kHJu\r\n\r\ngpt5.6 sol high： https://preview.kaka770.cn/tools/html-share?share=Kxsbbf\r\n\r\nKimi3.0： https://preview.kaka770.cn/tools/html-share?share=KdpYKL", "content_rendered": "一句话提示词：生成水墨风格的网站留言板页面<br /><br />gemini3.1 pro： <a target=\"_blank\" href=\"https://preview.kaka770.cn/tools/html-share?share=h8kHJu\" rel=\"nofollow noopener\">https://preview.kaka770.cn/tools/html-share?share=h8kHJu</a><br /><br />gpt5.6 sol high： <a target=\"_blank\" href=\"https://preview.kaka770.cn/tools/html-share?share=Kxsbbf\" rel=\"nofollow noopener\">https://preview.kaka770.cn/tools/html-share?share=Kxsbbf</a><br /><br />Kimi3.0： <a target=\"_blank\" href=\"https://preview.kaka770.cn/tools/html-share?share=KdpYKL\" rel=\"nofollow noopener\">https://preview.kaka770.cn/tools/html-share?share=KdpYKL</a>", "last_modified": 1784290860, "replies": 26, "id": 1228104}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23880, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3712, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 338820, "username": "frankkly", "url": "https://www.v2ex.com/u/frankkly", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_mini.png?m=1754288397", "avatar_normal": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_normal.png?m=1754288397", "avatar_large": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_large.png?m=1754288397", "avatar_xlarge": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_xlarge.png?m=1754288397", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_xxlarge.png?m=1754288397", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_xxxlarge.png?m=1754288397", "created": 1533524726, "last_modified": 1754288397, "pro": 0}, "last_reply_by": "pengyOne", "last_touched": 1784364130, "title": "裁员 n+1，已签解除合同，社保和公积金还能要求公司补吗？", "url": "https://www.v2ex.com/t/1228195", "created": 1784348242, "deleted": 0, "content": "7 月 15 号下午谈的，当时也不知道咋想的，n+1 就直接签了，事后想想挺傻逼的\r\n我们的社保和公积金都是按照最低的基数交的，我在支付宝里面查到公司的公积金缴费比例是 12%，社保的基数每年都不太一样，但是也都是按照最低交的，我当时也提了社保和公积金补偿，他们说社保只能补今年 1 月到 7 月，公积金说是要跟着公司上面集团一起补了才会补，后来感觉就是忽悠人的\r\n我让豆包按照我的工资水平算了一下，6 年，公司要给我补的钱大概一共是 38w7,这其中社保 26w6,公积金 12w1,然后我自己要补社保 10w6 ，公积金 12w1\r\n目前离职证明还没拿到，解除劳动合同签了，跟人事约了周一下午继续谈一下\r\n我想问问，假如我走投诉渠道去社保局和公积金中心，这笔钱我能拿到吗，就是打到我相应的账户里，我自己也补钱，再一个投诉渠道会不会给公司造成压力，公司会不会想跟我私下补一笔钱和解（不包含 n+1 ）\r\n杭州，国企性质，老板有编制，大家有类似的处理经验吗？", "content_rendered": "7 月 15 号下午谈的，当时也不知道咋想的，n+1 就直接签了，事后想想挺傻逼的<br />我们的社保和公积金都是按照最低的基数交的，我在支付宝里面查到公司的公积金缴费比例是 12%，社保的基数每年都不太一样，但是也都是按照最低交的，我当时也提了社保和公积金补偿，他们说社保只能补今年 1 月到 7 月，公积金说是要跟着公司上面集团一起补了才会补，后来感觉就是忽悠人的<br />我让豆包按照我的工资水平算了一下，6 年，公司要给我补的钱大概一共是 38w7,这其中社保 26w6,公积金 12w1,然后我自己要补社保 10w6 ，公积金 12w1<br />目前离职证明还没拿到，解除劳动合同签了，跟人事约了周一下午继续谈一下<br />我想问问，假如我走投诉渠道去社保局和公积金中心，这笔钱我能拿到吗，就是打到我相应的账户里，我自己也补钱，再一个投诉渠道会不会给公司造成压力，公司会不会想跟我私下补一笔钱和解（不包含 n+1 ）<br />杭州，国企性质，老板有编制，大家有类似的处理经验吗？", "last_modified": 1784351751, "replies": 25, "id": 1228195}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_large.png?m=1751736785", "name": "openai", "avatar_normal": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_normal.png?m=1751736785", "title": "OpenAI", "url": "https://www.v2ex.com/go/openai", "topics": 4321, "footer": "", "header": "关于 OpenAI 旗下产品 GPT，DALL·E，和 ChatGPT 的讨论。请不要在 V2EX 的回复中粘贴复制来自 AI 生成的文本。", "title_alternative": "OpenAI", "avatar_mini": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_mini.png?m=1751736785", "stars": 3225, "founder_id": 0, "aliases": [], "root": false, "id": 1135, "parent_node_name": "geek"}, "member": {"id": 688475, "username": "bilulanlv", "url": "https://www.v2ex.com/u/bilulanlv", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/7c0f2d1c493e04ece49e15c33bbfc44e?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/7c0f2d1c493e04ece49e15c33bbfc44e?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/7c0f2d1c493e04ece49e15c33bbfc44e?s=73&d=retro", "created": 1714965491, "last_modified": 1714965491, "pro": 0}, "last_reply_by": "evan9527", "last_touched": 1784360633, "title": "Codex 又又又重置了", "url": "https://www.v2ex.com/t/1228183", "created": 1784345579, "deleted": 0, "content": "还好忍住没用重置卡，竟然在 18%的时候又重置了。感觉有点赚翻了。", "content_rendered": "<p>还好忍住没用重置卡，竟然在 18%的时候又重置了。感觉有点赚翻了。</p>\n", "last_modified": 1784345579, "replies": 21, "id": 1228183}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6353/8fe6/519_large.png?m=1595507885", "name": "ideas", "avatar_normal": "https://cdn.v2ex.com/navatar/6353/8fe6/519_normal.png?m=1595507885", "title": "奇思妙想", "url": "https://www.v2ex.com/go/ideas", "topics": 6577, "footer": "", "header": "让你的创意在这里自由流动吧。", "title_alternative": "Ideas", "avatar_mini": "https://cdn.v2ex.com/navatar/6353/8fe6/519_mini.png?m=1595507885", "stars": 3242, "founder_id": 0, "aliases": [], "root": false, "id": 519, "parent_node_name": "v2ex"}, "member": {"id": 667968, "username": "mir490005", "url": "https://www.v2ex.com/u/mir490005", "website": "www.lbtool.cn", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/ed13aec6009395c647216e03d5efece4?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/ed13aec6009395c647216e03d5efece4?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/ed13aec6009395c647216e03d5efece4?s=73&d=retro", "created": 1703145555, "last_modified": 1703757864, "pro": 0}, "last_reply_by": "SenLief", "last_touched": 1784311744, "title": "Telegram 一搜全是灰产群，做了个过滤版收录站，想听听看法？", "url": "https://www.v2ex.com/t/1228077", "created": 1784281627, "deleted": 0, "content": "用 Telegram 搜索机器人找群，翻几页全是色情、赌博、兼职刷单、账号交易，正经群被淹得找不到。\r\n\r\n因为实在烦这个，做了 [QunTrust]( https://quntrust.com)，思路很简单：\r\n\r\n- 只收录公开群/频道/机器人；\r\n- 硬性关键词拦截 + 风险评分；\r\n- 每个群展示风险等级，高风险直接不索引；\r\n- 定期验活，失效就标记。\r\n\r\n现在的问题是**审核尺度**拿不准：\r\n\r\n1. 大家对这种\"过滤后\"的 Telegram 目录站有需求吗？\r\n2. 投资、兼职、账号交易这类灰产相关群，应该直接拒掉，还是收录但打风险提示？\r\n3. 还有什么判断群是否靠谱的好维度？\r\n\r\n欢迎吐槽和建议。", "content_rendered": "<p>用 Telegram 搜索机器人找群，翻几页全是色情、赌博、兼职刷单、账号交易，正经群被淹得找不到。</p>\n<p>因为实在烦这个，做了 <a href=\"https://quntrust.com\" rel=\"nofollow\">QunTrust</a>，思路很简单：</p>\n<ul>\n<li>只收录公开群/频道/机器人；</li>\n<li>硬性关键词拦截 + 风险评分；</li>\n<li>每个群展示风险等级，高风险直接不索引；</li>\n<li>定期验活，失效就标记。</li>\n</ul>\n<p>现在的问题是<strong>审核尺度</strong>拿不准：</p>\n<ol>\n<li>大家对这种\"过滤后\"的 Telegram 目录站有需求吗？</li>\n<li>投资、兼职、账号交易这类灰产相关群，应该直接拒掉，还是收录但打风险提示？</li>\n<li>还有什么判断群是否靠谱的好维度？</li>\n</ol>\n<p>欢迎吐槽和建议。</p>\n", "last_modified": 1784281691, "replies": 20, "id": 1228077}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23880, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3712, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 797202, "username": "wobuchiyu", "url": "https://www.v2ex.com/u/wobuchiyu", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "我不爱吃鱼", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_mini.png?m=1780382015", "avatar_normal": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_normal.png?m=1780382015", "avatar_large": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_large.png?m=1780382015", "avatar_xlarge": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_xlarge.png?m=1780382015", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_xxlarge.png?m=1780382015", "created": 1774418682, "last_modified": 1780382015, "pro": 0}, "last_reply_by": "wobuchiyu", "last_touched": 1784362749, "title": "我发现真的只有互联网行业自己卷死自己，自己把自己的工作整没了。", "url": "https://www.v2ex.com/t/1228193", "created": 1784347542, "deleted": 0, "content": "应该只有互联网开发会出现所谓的 35 斩杀线吧，并且经验完全没有用，瞬间被 ai 替代。 像机械 电子 这种，开源好像没有计算机的多。经验多的老师傅 完全不担心失业。 但是就算你是全栈 资深  高级，  算法  在 ai 出来后，人人自危。   \r\n\r\n还有今年冒出来的 agent 开发工程师。 公司真的需要这玩意吗，造需求，就更 3 月份的龙虾一样。等 agent 开发完了。还需要那么多 agent 开发吗？最后还是自己把自己干死了。", "content_rendered": "应该只有互联网开发会出现所谓的 35 斩杀线吧，并且经验完全没有用，瞬间被 ai 替代。 像机械 电子 这种，开源好像没有计算机的多。经验多的老师傅 完全不担心失业。 但是就算你是全栈 资深  高级，  算法  在 ai 出来后，人人自危。   <br /><br />还有今年冒出来的 agent 开发工程师。 公司真的需要这玩意吗，造需求，就更 3 月份的龙虾一样。等 agent 开发完了。还需要那么多 agent 开发吗？最后还是自己把自己干死了。", "last_modified": 1784347760, "replies": 20, "id": 1228193}]